# Two .env files are needed for local development:
#
#   .env (project root) -- used by docker-compose. Change hostnames to Docker service names:
#     DATABASE_URL=postgresql+asyncpg://trawl:trawl@db:5432/trawl
#     REDIS_URL=redis://redis:6379/0
#
#   backend/.env -- used by uvicorn and Celery when running locally. Keep hostnames as localhost (defaults below).
#
# Both files are gitignored.

DATABASE_URL=postgresql+asyncpg://trawl:trawl@localhost:5432/trawl

REDIS_URL=redis://localhost:6379/0

ANTHROPIC_API_KEY=sk-ant-your-key-here

VOYAGE_API_KEY=pa-your-key-here

JWT_SECRET=change-this-to-a-random-string

# Frontend vars go in frontend/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-this-to-a-random-string
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
