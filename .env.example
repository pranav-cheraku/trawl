# ===========================================
# Trawl Environment Variables
# ===========================================
#
# TWO .env files are needed for local development:
#
# 1. .env (project root) — used by docker-compose for containers
#    cp .env.example .env
#    Then change hostnames to Docker service names:
#      DATABASE_URL=postgresql+asyncpg://trawl:trawl@db:5432/trawl
#      REDIS_URL=redis://redis:6379/0
#
# 2. backend/.env — used by uvicorn + Celery when running locally
#    cp .env.example backend/.env
#    Keep hostnames as localhost (default below).
#
# Both files are gitignored.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://trawl:trawl@localhost:5432/trawl

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Voyage AI (Embeddings) ---
VOYAGE_API_KEY=pa-your-key-here

# --- Auth ---
JWT_SECRET=change-this-to-a-random-string

# --- Frontend (create frontend/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-this-to-a-random-string
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
