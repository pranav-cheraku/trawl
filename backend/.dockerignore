# Keeps the Docker build context lean. Excludes local tooling, caches, secrets,
# and test files that are not needed inside the runtime image.

# Local virtualenvs
venv/
.venv/

# Python caches
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.mypy_cache/
.pytest_cache/

# Tests are not needed in the runtime image
tests/

# Secrets and local files
.env
.git/
