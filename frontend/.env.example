# frontend/.env.local — copy this file to frontend/.env.local and fill in real values.
# This file is safe to commit (placeholder values only).

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe price IDs (test mode). Copied from Stripe Dashboard → Products.
NEXT_PUBLIC_STRIPE_PRICE_SMALL=price_test_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_LARGE=price_test_yyyyy

# Public demo. Must match backend DEMO_TOKEN.
NEXT_PUBLIC_DEMO_TOKEN=dev-demo-token-change-in-production
NEXT_PUBLIC_DEMO_PROJECT_ID=00000000-0000-0000-0000-0000000000d0
